{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5-fast",
  "default_agent": "brainstorm",
  "instructions": ["./prompts/_core.md"],
  "permission": {
    "skill": {
      "*": "ask"
    }
  },
  "agent": {
    "brainstorm": {
      "description": "Clarify, challenge, scope, compare options, and decide the next agent without modifying files.",
      "mode": "primary",
      "model": "openai/gpt-5.5-fast",
      "variant": "low",
      "temperature": 0.5,
      "prompt": "{file:./prompts/brainstorm.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "*capture.sh*": "allow"
        },
        "question": "allow",
        "todowrite": "deny",
        "skill": {
          "*": "ask"
        }
      }
    },
    "plan": {
      "description": "Inspect the codebase in read-only mode and produce an execution-ready plan.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "variant": "high",
      "temperature": 0.1,
      "prompt": "{file:./prompts/plan.md}\n\n{file:./prompts/pattern-radar.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "*capture.sh*": "allow"
        },
        "question": "allow",
        "todowrite": "allow",
        "skill": {
          "*": "ask"
        }
      }
    },
    "build": {
      "description": "Implement the approved plan with minimal diffs and targeted validation.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "temperature": 0,
      "prompt": "{file:./prompts/build.md}",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "*capture.sh*": "allow"
        },
        "question": "allow",
        "todowrite": "allow",
        "skill": {
          "*": "ask"
        }
      }
    },
    "review": {
      "description": "Review changes in strict read-only mode for correctness, regressions, maintainability, and client constraints.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "variant": "high",
      "temperature": 0,
      "prompt": "{file:./prompts/review.md}\n\n{file:./prompts/pattern-radar.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "*capture.sh*": "allow"
        },
        "question": "allow",
        "todowrite": "allow",
        "skill": {
          "*": "ask"
        }
      }
    },
    "pattern-scan": {
      "description": "On-demand read-only scanner. Invoke when onboarding on an unfamiliar codebase to map its architectural, JavaScript, and framework patterns/anti-patterns. No plan, no changes.",
      "mode": "subagent",
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",
      "temperature": 0.1,
      "prompt": "{file:./prompts/pattern-scan.md}\n\n{file:./prompts/pattern-radar.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "question": "allow",
        "todowrite": "allow",
        "skill": {
          "*": "ask"
        }
      }
    }
  }
}
