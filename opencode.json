{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5-fast",
  "default_agent": "chat",
  "permission": {
    "skill": {
      "*": "ask"
    }
  },
  "agent": {
    "chat": {
      "description": "Brainstorm, discuss, clarify ideas, explore product/design/technical options without modifying files.",
      "mode": "primary",
      "model": "openai/gpt-5.5-fast",
      "prompt": "{file:./prompts/chat.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "skill": {
          "*": "ask"
        }
      },
      "options": {}
    },
    "plan": {
      "description": "Turns a validated idea into an execution-ready implementation plan without making code changes.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "skill": {
          "*": "ask"
        }
      },
      "options": {}
    },
    "build": {
      "description": "Implements the approved plan with minimal diffs, project-aware execution, and targeted validation.",
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./prompts/build.md}",
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "skill": {
          "*": "ask"
        }
      },
      "options": {}
    },
    "general": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "explore": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "mentor": {
      "disable": true,
      "options": {},
      "permission": {}
    },
    "review": {
      "disable": true,
      "options": {},
      "permission": {}
    }
  }
}